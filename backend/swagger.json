  "info": {
    "title": "API Iluminación Inteligente",
    "version": "1.0",
    "description": "API REST para monitoreo y control de iluminación inteligente"
  },
  "produces": [
    "application/json"
  ],
  "consumes": [
    "application/json"
  ],
  "tags": [
    {
      "name": "sensores",
      "description": "Registro y lectura de datos del sensor"
    },
    {
      "name": "actividades",
      "description": "Gestión de actividades"
    },
    {
      "name": "configuracion",
      "description": "Gestión de configuración del sistema"
    },
    {
      "name": "usuarios",
      "description": "Gestión de usuarios"
    },
    {
      "name": "historial",
      "description": "Consulta de historial de iluminación"
    },
    {
      "name": "consumo",
      "description": "Gestión de consumo energético"
    },
    {
      "name": "salones",
      "description": "Gestión de salones"
    },
    {
      "name": "dashboard",
      "description": "Dashboard y últimas lecturas por salón"
    },
    {
      "name": "health",
      "description": "Chequeo de salud del API"
    },
    {
      "name": "reportes",
      "description": "Reportes e historial de iluminación"
    }
  ],
  "definitions": {
    "SensorInput": {
      "required": [
        "consumo_energetico",
        "intensidad_led",
        "lux",
        "modo_automatico",
        "salon_id"
      ],
      "properties": {
        "salon_id": {
          "type": "integer",
          "description": "ID del salón asociado",
          "example": 1
        },
        "lux": {
          "type": "number",
          "description": "Nivel de luminosidad ambiental",
          "example": 210.5
        },
        "intensidad_led": {
          "type": "integer",
          "description": "Intensidad del LED",
          "example": 65
        },
        "consumo_energetico": {
          "type": "number",
          "description": "Consumo energético en kWh",
          "example": 0.85
        },
        "modo_automatico": {
          "type": "boolean",
          "description": "Modo automático/manual",
          "example": true
        },
        "actividad_id": {
          "type": "integer",
          "description": "ID de actividad asociada"
        }
      },
      "type": "object"
    },
    "Sensor": {
      "properties": {
        "id": {
          "type": "integer",
          "description": "ID del registro de sensor",
          "readOnly": true
        },
        "salon_id": {
          "type": "integer",
          "description": "ID del salón asociado"
        },
        "lux": {
          "type": "number",
          "description": "Nivel de luminosidad ambiental"
        },
        "intensidad_led": {
          "type": "integer",
          "description": "Intensidad LED actual"
        },
        "consumo_energetico": {
          "type": "number",
          "description": "Consumo energético actual"
        },
        "modo_automatico": {
          "type": "boolean",
          "description": "Indica si el modo es automático"
        },
        "actividad_id": {
          "type": "integer",
          "description": "Actividad asociada"
        },
        "registrado_en": {
          "type": "string",
          "format": "date-time",
          "description": "Fecha y hora de registro"
        }
      },
      "type": "object"
    },
    "PaginatedSensores": {
      "properties": {
        "items": {
          "type": "array",
          "description": "Registros de sensores por página",
          "items": {
            "$ref": "#/definitions/Sensor"
          }
        },
        "page": {
          "type": "integer",
          "description": "Página actual",
          "example": 1
        },
        "limit": {
          "type": "integer",
          "description": "Límite de registros por página",
          "example": 20
        },
        "total": {
          "type": "integer",
          "description": "Total de registros disponibles",
          "example": 100
        }
      },
      "type": "object"
    },
    "Actividad": {
      "required": [
        "nombre"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "description": "ID de la actividad",
          "readOnly": true
        },
        "nombre": {
          "type": "string",
          "description": "Nombre de la actividad",
          "example": "Conferencia"
        },
        "descripcion": {
          "type": "string",
          "description": "Descripción de la actividad",
          "example": "Reunión general en sala principal"
        }
      },
      "type": "object"
    },
    "Configuracion": {
      "required": [
        "intensidad_led_default",
        "max_consumo",
        "modo_automatico",
        "umbral_lux"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "description": "ID de configuración",
          "readOnly": true
        },
        "modo_automatico": {
          "type": "boolean",
          "description": "Modo automático habilitado"
        },
        "intensidad_led_default": {
          "type": "integer",
          "description": "Intensidad LED por defecto"
        },
        "umbral_lux": {
          "type": "integer",
          "description": "Umbral de luminosidad ambiental"
        },
        "max_consumo": {
          "type": "number",
          "description": "Máximo consumo energético permitido"
        }
      },
